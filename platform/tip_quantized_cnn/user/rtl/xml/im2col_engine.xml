<?xml version="1.0" ?>
<rvx>
	<dec_ip>
		<name>im2col_engine</name>
		<hdl_name>USER_IM2COL_ENGINE</hdl_name>

		<def_parameter user_editable="True">
			<name>SIZE_OF_MEMORYMAP</name>
			<value>0x1000</value>
		</def_parameter>
		<def_parameter user_editable="True">
			<name>BW_ADDR</name>
			<value>32</value>
		</def_parameter>
		<def_parameter user_editable="True">
			<name>BW_APB_DATA</name>
			<value>32</value>
		</def_parameter>
		<def_parameter user_editable="True">
			<name>BW_AXI_DATA</name>
			<value>32</value>
		</def_parameter>
		<def_parameter user_editable="True">
			<name>BW_AXI_TID</name>
			<value>2</value>
		</def_parameter>

		<user_dependent/>

		<signal>
			<name>clk</name>
			<width>1</width>
			<port>input</port>
			<comm_type>clk_system</comm_type>
		</signal>

		<signal>
			<name>rstnn</name>
			<width>1</width>
			<port>input</port>
		</signal>

		<reset_property>
			<id>rstnn</id>
			<type>asynch</type>
			<type>negative</type>
			<group>3</group>
		</reset_property>

		<core>
			<sync>clk</sync>
			<init>rstnn</init>
		</core>

		<interface>
			<name>control</name>
			<library_name>apb</library_name>
			<hdl_prefix></hdl_prefix>
			<role>receiver</role>
			<comm_type>memory:all</comm_type>
			<memorymap>
				<size>SIZE_OF_MEMORYMAP</size>
			</memorymap>
			<parameter>
				<id>bw_addr</id>
				<value>BW_ADDR</value>
			</parameter>
			<parameter>
				<id>bw_data</id>
				<value>BW_APB_DATA</value>
			</parameter>
			<sync>clk</sync>
			<init>rstnn</init>
		</interface>

		<interface>
			<name>master</name>
			<library_name>axi</library_name>
			<hdl_prefix></hdl_prefix>
			<role>sender</role>
			<comm_type>memory:all</comm_type>
			<parameter>
				<id>bw_addr</id>
				<value>BW_ADDR</value>
			</parameter>
			<parameter>
				<id>bw_data</id>
				<value>BW_AXI_DATA</value>
			</parameter>
			<parameter>
				<id>bw_tid</id>
				<value>BW_AXI_TID</value>
			</parameter>
			<sync>clk</sync>
			<init>rstnn</init>
		</interface>
	</dec_ip>
</rvx>
