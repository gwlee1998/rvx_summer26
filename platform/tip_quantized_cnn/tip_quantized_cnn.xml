<?xml version="1.0" ?>
<rvx>
	<platform>
		<name>tip_quantized_cnn</name>
		<status>described</status>
		<spec>
			<define>
				<name>sram_size</name>
				<value>128kB</value>
			</define>
			<define>
				<name>include_slow_dram</name>
				<value>True</value>
			</define>

			<define>
				<name>num_led_checker</name>
				<value>1</value>
			</define>
		</spec>


		<ip_instance>
			<name>i_main_core</name>
			<library_name>rvc_orca</library_name>

		</ip_instance>

		<ip_instance>
			<name>i_im2col</name>
			<library_name>im2col_engine</library_name>
			<parameter>
				<id>SIZE_OF_MEMORYMAP</id>
				<value>0x1000</value>
			</parameter>
			<parameter>
				<id>BW_ADDR</id>
				<value>32</value>
			</parameter>
			<parameter>
				<id>BW_APB_DATA</id>
				<value>32</value>
			</parameter>
			<parameter>
				<id>BW_AXI_DATA</id>
				<value>32</value>
			</parameter>
			<parameter>
				<id>BW_AXI_TID</id>
				<value>2</value>
			</parameter>
		</ip_instance>

		<ip_instance>
			<name>i_gemm_requant</name>
			<library_name>gemm_requant_engine</library_name>
			<parameter>
				<id>SIZE_OF_MEMORYMAP</id>
				<value>0x1000</value>
			</parameter>
			<parameter>
				<id>BW_ADDR</id>
				<value>32</value>
			</parameter>
			<parameter>
				<id>BW_APB_DATA</id>
				<value>32</value>
			</parameter>
			<parameter>
				<id>BW_AXI_DATA</id>
				<value>32</value>
			</parameter>
			<parameter>
				<id>BW_AXI_TID</id>
				<value>2</value>
			</parameter>
		</ip_instance>
	</platform>
</rvx>
